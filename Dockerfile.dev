# Use Node.js LTS version
FROM node:18-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install ALL dependencies (including dev dependencies for nodemon)
RUN npm install

# Copy application files
COPY . .

# Expose port
EXPOSE 5000

# Start with nodemon for auto-reload on file changes
CMD ["npm", "run", "dev"]
